---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Fabricante OEM de Electrodomésticos en China | Hervidores, Arroceras y Más',
  description:
    'Fabricante OEM y ODM en China de pequeños electrodomésticos. Producción de hervidores eléctricos, arroceras, ollas a presión y batidoras. Proveedor para marcas, importadores y distribuidores globales.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

<Hero
  actions={[
    {
      variant: 'primary',
      text: 'Solicitar Cotización',
      href: '/contacto',
      icon: 'tabler:message',
    },
    {
      text: 'Ver Catálogo de Productos OEM/ODM',
      href: 'https://www.yolec-electronics.com/products/',
    },
  ]}
  image={{
    src: '~/assets/images/oem.png',
    alt: 'OEM ODM manufacturer of electric kettles, rice cookers and small kitchen appliances in China - YOLEC Electric factory',
  }}
>
  <Fragment slot="title">
    OEM & ODM Manufacturer of <span class="text-accent dark:text-white">Small Kitchen Appliances</span> in China
  </Fragment>

  <Fragment slot="subtitle">
    <strong>YOLEC Electric</strong> is a professional OEM/ODM manufacturer in China specializing in electric kettles, gooseneck kettles, rice cookers, electric pressure cookers, lunch boxes, and hand mixers. We help global brands, importers, and distributors build customized kitchen appliance products with factory-direct solutions since 2015. Somos un fabricante confiable en China para importadores y distribuidores de electrodomésticos OEM.
  </Fragment>
</Hero>
<h1 class="sr-only">
  Fabricante OEM de electrodomésticos en China - Hervidores eléctricos, arroceras y más
</h1>

  <!-- Note Widget ******************* -->

  <Note
    title="Fabricante OEM y ODM de confianza desde 2015"
    description="Más de 20.000 m² de fábrica, más de 200 empleados, certificación SGS, talleres propios de fundición e inyección y más de 8 años exportando pequeños electrodomésticos para marcas internacionales."
  />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="YOLEC ELECTRIC"
    title="¿Por qué elegir nuestro fabricante OEM de pequeños electrodomésticos?"
    subtitle="Ofrecemos soluciones completas de fabricación OEM y ODM para marcas internacionales con estrictos estándares de calidad, producción eficiente y más de 10 años de experiencia en exportación."
    items={[
      {
        title: 'Más de 20.000 m² de fábrica',
        description:
          'Instalaciones modernas con talleres propios de fundición a presión, inyección de plástico y ensamblaje.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Más de 200 empleados',
        description:
          'Ingenieros, técnicos y especialistas en producción trabajan para garantizar una fabricación estable y eficiente.',
        icon: 'tabler:users',
      },
      {
        title: '3 líneas de producción',
        description:
          'Capacidad suficiente para pedidos OEM de gran volumen con entregas puntuales.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Fábrica certificada por SGS',
        description:
          'Procesos auditados para ofrecer calidad constante y confianza a compradores internacionales.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Certificaciones internacionales',
        description:
          'Productos conformes con CE, CB, LFGB, RoHS, ERP y otros requisitos de los mercados europeos.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Más de 8 años en Alibaba.com',
        description:
          'Proveedor OEM verificado con amplia experiencia atendiendo importadores y distribuidores de todo el mundo.',
        icon: 'tabler:world',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="SERVICIOS OEM Y ODM"
    title="Desarrollamos y fabricamos pequeños electrodomésticos para su marca"
    items={[
      {
        title: 'OEM para marcas privadas',
        description:
          'Fabricamos productos con su logotipo, embalaje y especificaciones técnicas.',
      },
      {
        title: 'Desarrollo ODM',
        description:
          'Nuestro equipo de I+D desarrolla nuevos productos adaptados a las necesidades de su mercado.',
      },
      {
        title: 'Diseño de embalaje',
        description:
          'Personalizamos cajas de color, manuales, etiquetas y accesorios para fortalecer su marca.',
      },
      {
        title: 'Control de calidad',
        description:
          'Cada producto pasa por estrictas inspecciones antes del envío para garantizar una calidad constante.',
      },
    ]}
    image={{
      src: '~/assets/images/oem-1.png',
      alt: 'Servicio OEM y ODM de pequeños electrodomésticos',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Soluciones completas desde el diseño hasta la producción en masa
      </h3>

      Trabajamos con importadores, distribuidores, supermercados y marcas internacionales para ofrecer servicios OEM y ODM rápidos, flexibles y rentables.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="PRODUCTOS OEM"
    title="Categorías de pequeños electrodomésticos que fabricamos"
    items={[
      {
        title: 'Hervidores eléctricos',
        description: 'Hervidores rápidos para uso doméstico y comercial con diseño moderno y duradero.',
      },
      {
        title: 'Hervidores cuello de cisne',
        description: 'Perfectos para café pour-over, con control preciso del flujo de agua.',
      },
      {
        title: 'Arroceras eléctricas',
        description: 'Soluciones eficientes para cocción de arroz con múltiples funciones.',
      },
      {
        title: 'Ollas a presión eléctricas',
        description: 'Cocción rápida y segura para diferentes tipos de alimentos.',
      },
      {
        title: 'Fiambreras eléctricas',
        description: 'Ideal para oficina, viaje y uso portátil diario.',
      },
      {
        title: 'Batidoras de mano',
        description: 'Diseño compacto para cocina doméstica y uso profesional ligero.',
      },
    ]}
    image={{
      src: '~/assets/images/oem-6.jpg',
      alt: 'Categorías de productos OEM pequeños electrodomésticos',
    }}
  >
    <Fragment slot="content">
      Nuestros productos están diseñados para mercados internacionales con certificaciones y estándares de calidad exigidos en Europa, América y Asia.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="PROCESO DE FABRICACIÓN"
    title="Controlamos todo el proceso de fabricación para garantizar calidad y entrega puntual"
    items={[
      {
        title: 'Diseño y evaluación del proyecto',
        description:
          'Analizamos sus requisitos, mercado objetivo y especificaciones técnicas antes de iniciar el desarrollo.',
      },
      {
        title: 'Fabricación de moldes y muestras',
        description:
          'Desarrollamos moldes, prototipos y muestras para confirmar todos los detalles del producto.',
      },
      {
        title: 'Producción en serie',
        description:
          'Nuestras líneas de producción garantizan una fabricación estable y una alta capacidad para pedidos OEM.',
      },
      {
        title: 'Inspección de calidad y envío',
        description:
          'Realizamos estrictos controles de calidad antes del embalaje y la exportación para asegurar productos confiables.',
      },
    ]}
    image={{
      src: '~/assets/images/oem-4.png',
      alt: 'Proceso de fabricación OEM de pequeños electrodomésticos',
    }}
  >
    <Fragment slot="content">
      Desde la idea inicial hasta la entrega final, ofrecemos un servicio integral para ayudar a nuestros clientes a lanzar productos competitivos con rapidez y seguridad.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Cómo trabajamos con marcas internacionales OEM / ODM"
    subtitle="Proceso claro, controlado y transparente desde la idea hasta la entrega global"
    items={[
      {
        title: 'Envío de consulta y evaluación',
        description:
          'El cliente envía su idea de producto, especificaciones o mercado objetivo. Nuestro equipo realiza una evaluación inicial rápida.',
      },
      {
        title: 'Desarrollo de solución OEM / ODM',
        description:
          'Definimos diseño, materiales, funciones, embalaje y requisitos técnicos según su marca y mercado.',
      },
      {
        title: 'Producción en masa con control de calidad',
        description:
          'Fabricación en nuestras líneas de producción con control de calidad en cada etapa para garantizar consistencia.',
      },
      {
        title: 'Inspección final y envío internacional',
        description:
          'Revisión final, embalaje profesional y coordinación logística para entrega segura a su país.',
      },
    ]}
    image={{
      src: '~/assets/images/oem-5.png',
      alt: 'Proceso de fabricación OEM ODM de pequeños electrodomésticos',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="¿Por qué elegir YOLEC Electric?"
    subtitle="Ofrecemos soluciones OEM y ODM para pequeños electrodomésticos, ayudando a las marcas globales a desarrollar productos competitivos con una fabricación fiable en China."
    tagline="Ventajas"
    items={[
      {
        title: 'Fabricación OEM',
        description:
          'Desarrollamos y fabricamos pequeños electrodomésticos personalizados según las especificaciones, el diseño y la marca de cada cliente.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Servicio ODM',
        description:
          'Disponemos de modelos listos para fabricar que pueden personalizarse con su logotipo, embalaje y requisitos comerciales.',
        icon: 'flat-color-icons:gallery',
      },
      {
        title: 'Control de Calidad',
        description:
          'Cada producto pasa por estrictos procesos de inspección y pruebas para garantizar un rendimiento estable y una calidad constante.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Desarrollo de Productos',
        description:
          'Nuestro equipo de ingeniería transforma ideas en productos listos para el mercado con soporte técnico profesional.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Producción Flexible',
        description:
          'Aceptamos diferentes volúmenes de pedido y ofrecemos una producción eficiente para satisfacer las necesidades de cada cliente.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Precios Competitivos',
        description:
          'La fabricación directa en nuestra fábrica permite ofrecer una excelente relación calidad-precio para compradores internacionales.',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: 'Exportación Global',
        description:
          'Nuestros productos se exportan a numerosos países y regiones, apoyando a distribuidores, importadores y marcas internacionales.',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: 'Soporte Profesional',
        description:
          'Brindamos comunicación rápida, seguimiento de pedidos y asistencia técnica durante todo el proceso de cooperación.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Cooperación a Largo Plazo',
        description:
          'Nuestro objetivo es construir relaciones comerciales duraderas mediante calidad estable, entrega puntual y un servicio confiable.',
        icon: 'flat-color-icons:database',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Centro de Conocimiento sobre Fabricación OEM de Electrodomésticos"
    information={`Descubra artículos profesionales sobre fabricación OEM y ODM, control de calidad, desarrollo de productos, tendencias del mercado y abastecimiento de pequeños electrodomésticos en China. Nuestro blog ayuda a importadores, distribuidores, propietarios de marcas y compradores internacionales a tomar decisiones de compra más informadas y encontrar un fabricante confiable para colaboraciones a largo plazo.`}
  />

  <!-- FAQs Widget ******************* -->

<FAQs
  title="Preguntas Frecuentes"
  subtitle="Encuentre respuestas a las preguntas más comunes sobre nuestros servicios OEM y ODM para pequeños electrodomésticos."
  tagline="FAQ"
  classes={{ container: 'max-w-6xl' }}
  items={[
    {
      title: '¿Qué productos fabrica YOLEC Electric?',
      description:
        'Nos especializamos en la fabricación OEM y ODM de pequeños electrodomésticos, incluyendo hervidores eléctricos, arroceras, ollas a presión eléctricas, fiambreras eléctricas y batidoras de mano para marcas de todo el mundo.',
    },
    {
      title: '¿Ofrecen servicios OEM y ODM?',
      description:
        'Sí. Podemos fabricar productos según sus diseños, especificaciones técnicas, logotipo, embalaje y requisitos de marca. También disponemos de modelos ODM listos para personalizar.',
    },
    {
      title: '¿Cuál es la cantidad mínima de pedido (MOQ)?',
      description:
        'La cantidad mínima depende del producto y del nivel de personalización requerido. Nuestro equipo de ventas le ofrecerá la mejor solución según las necesidades de su proyecto.',
    },
    {
      title: '¿Qué certificaciones tienen sus productos?',
      description:
        'Podemos suministrar productos que cumplen con diferentes normativas internacionales, incluyendo CE, CB, GS, LFGB, RoHS y otras certificaciones, según el mercado de destino.',
    },
    {
      title: '¿Cómo garantizan la calidad del producto?',
      description:
        'Aplicamos un estricto sistema de control de calidad durante todo el proceso de producción, incluyendo inspección de materiales, pruebas en línea, pruebas funcionales e inspección final antes del envío.',
    },
    {
      title: '¿Exportan a otros países?',
      description:
        'Sí. Exportamos pequeños electrodomésticos a Europa, Oriente Medio, Sudamérica, África y otros mercados internacionales, ofreciendo soluciones de fabricación fiables para importadores, distribuidores y propietarios de marcas.',
    },
  ]}
/>

  <!-- Stats Widget ****************** -->

<Stats
  stats={[
    { title: 'Años de experiencia OEM', amount: '15+' },
    { title: 'Clientes globales', amount: '200+' },
    { title: 'Capacidad mensual', amount: '300K+' },
    { title: 'Países exportados', amount: '60+' },
  ]}
/>
  <!-- CallToAction Widget *********** -->



<CallToAction
  actions={[
    {
      variant: 'primary',
      text: 'Solicitar cotización OEM',
      href: '/contact',
      icon: 'tabler:mail',
    },
  ]}
>
  <Fragment slot="title">
    Fabricante OEM de<br class="block sm:hidden" />
    <span class="sm:whitespace-nowrap">Electrodomésticos en China</span>
  </Fragment>

  <Fragment slot="subtitle">
    Producción personalizada de hervidores eléctricos, arroceras, ollas a presión y más.<br class="hidden md:inline" />
    Contáctanos para soluciones OEM/ODM para tu marca.
  </Fragment>
</CallToAction>

<div class="flex flex-col justify-center items-center mt-10 gap-3">
  <p class="text-sm md:text-base text-gray-600 dark:text-slate-300 text-center">
    Contacto directo para consultas OEM/ODM (WhatsApp)
  </p>

  <img
    src="~/assets/images/whatsapp.png"
    alt="Contacto directo con fabricantes OEM de electrodomésticos de cocina en China a través de WhatsApp y WeChat"
    class="mx-auto max-w-full h-auto w-[180px] md:w-[220px] rounded-lg shadow-md"
    loading="lazy"
  />
</div>

</Layout>
