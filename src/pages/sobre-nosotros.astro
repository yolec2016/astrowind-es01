---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Sobre Nosotros | Fabricante OEM y ODM de Pequeños Electrodomésticos en China | YOLEC Electric',
  description:
    'Conozca YOLEC Electric, fabricante OEM y ODM de pequeños electrodomésticos en China. Más de 20.000 m² de fábrica, fabricación de hervidores eléctricos, arroceras, ollas a presión, fiambreras eléctricas y batidoras para importadores y marcas internacionales.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- HERO -->
  <Hero
    tagline="Fabricante OEM y ODM de Electrodomésticos en China"
    title="YOLEC Electric: Fabricante OEM y ODM de Pequeños Electrodomésticos para Marcas Globales"
    subtitle="YOLEC Electric es un fabricante profesional de pequeños electrodomésticos ubicado en Zhongshan, China. Desde 2015 ayudamos a importadores, distribuidores, cadenas minoristas y propietarios de marcas a desarrollar y fabricar hervidores eléctricos, hervidores de cuello de cisne, arroceras, ollas a presión eléctricas, fiambreras eléctricas y batidoras de mano mediante soluciones OEM y ODM completas. Con producción directa de fábrica, un estricto sistema de control de calidad y una amplia experiencia en exportación, ofrecemos productos fiables para mercados de Europa, América, Oriente Medio y otras regiones."
    image={{
      src: '~/assets/images/yolec.png',
      alt: 'Fábrica OEM y ODM de pequeños electrodomésticos en Zhongshan, China - YOLEC Electric',
    }}
  />
  <!-- STATS -->
  <Stats
    title="Capacidad de fabricación"
    stats={[
      { title: 'Años de experiencia', amount: '10+' },
      { title: 'Capacidad mensual', amount: '300K+' },
      { title: 'Clientes B2B', amount: '200+' },
      { title: 'Líneas de producción', amount: '3' },
    ]}
  />

  <!-- FEATURES -->
  <Features3
    title="¿Por qué elegir YOLEC Electric?"
    subtitle="Somos un fabricante OEM y ODM especializado en pequeños electrodomésticos para clientes B2B de todo el mundo, ofreciendo desarrollo de productos, producción personalizada y estrictos controles de calidad."
    columns={3}
    items={[
      {
        title: 'Fabricación OEM/ODM',
        description: 'Desarrollamos productos personalizados según la marca y necesidades del cliente.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Control de calidad estricto',
        description: 'Inspección en cada etapa de producción para garantizar estándares internacionales.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Ingeniería propia',
        description: 'Equipo de diseño y desarrollo para soluciones ODM completas.',
        icon: 'tabler:settings-cog',
      },
      {
        title: 'Exportación global',
        description: 'Experiencia en envío a Europa, América, Oriente Medio y Asia.',
        icon: 'tabler:world',
      },
      {
        title: 'Producción flexible',
        description: 'Adaptamos el MOQ y la capacidad según el tipo de cliente.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Soporte B2B directo',
        description: 'Comunicación directa con fábrica sin intermediarios.',
        icon: 'tabler:messages',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

<Content
  isReversed
  tagline="VISITE NUESTRA FÁBRICA"
  title="Le invitamos a visitar nuestra fábrica en China"
  image={{
    src: '~/assets/images/factory3.png',
    alt: 'Clientes internacionales visitando la fábrica de YOLEC Electric en China',
  }}
>

  <Fragment slot="content">

    <p class="mb-5">
      Siempre damos una cálida bienvenida a nuestros clientes y socios comerciales para visitar nuestra fábrica en Zhongshan, Guangdong, China.
    </p>

    <p class="mb-5">
      Durante la visita podrá conocer nuestras líneas de producción, procesos de fabricación, laboratorio de pruebas, sistema de control de calidad y equipo de ingeniería.
    </p>

    <p class="mb-5">
      Creemos que una visita presencial es la mejor manera de conocer nuestra capacidad de fabricación y establecer una relación de cooperación basada en la confianza.
    </p>

    <p>
      Nuestro equipo estará encantado de organizar la recepción, el recorrido por la fábrica y reuniones técnicas para ayudarle a comprender mejor nuestras soluciones OEM y ODM.
    </p>

  </Fragment>

</Content>

  <!-- PROCESS -->
  <Steps2
    title="Nuestro proceso de cooperación OEM y ODM"
    subtitle="Desde la consulta inicial hasta la entrega internacional, ofrecemos un proceso eficiente y transparente para compradores profesionales."
    items={[
      {
        title: 'Consulta del proyecto',
        description: 'Analizamos requisitos del producto, mercado objetivo y volumen.',
      },
      {
        title: 'Propuesta OEM/ODM',
        description: 'Recomendamos modelo de fabricación y solución técnica.',
      },
      {
        title: 'Diseño y muestra',
        description: 'Desarrollo de prototipo o adaptación de modelo existente.',
      },
      {
        title: 'Producción en masa',
        description: 'Fabricación bajo control de calidad estricto.',
      },
      {
        title: 'Inspección final',
        description: 'Revisión AQL y pruebas funcionales antes del envío.',
      },
      {
        title: 'Entrega global',
        description: 'Logística internacional y soporte documental de exportación.',
      },
    ]}
  />


<CallToAction
  actions={[
    {
      variant: 'primary',
      text: 'Solicitar Cotización OEM',
      href: '/contacto',
      icon: 'tabler:mail',
    },
    {
      text: 'Contactar por WhatsApp',
      href: 'https://wa.me/8613922332584',
    },
  ]}
>

  <Fragment slot="title">
    ¿Busca un fabricante OEM y ODM confiable en China?
  </Fragment>

  <Fragment slot="subtitle">
    Nuestro equipo está preparado para ayudarle a desarrollar nuevos productos, fabricar con su propia marca y ofrecer soluciones OEM y ODM adaptadas a su mercado. Contáctenos hoy mismo para recibir una propuesta personalizada.
  </Fragment>

</CallToAction>  

</Layout>